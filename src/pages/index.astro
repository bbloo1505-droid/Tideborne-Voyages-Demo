---
import BaseLayout from "../layouts/BaseLayout.astro";
import { services } from "../data/services.ts";
import { brand } from "../data/brand.ts";
---

<BaseLayout title={brand.defaultTitle} description={brand.defaultDescription}>
  <main id="main">
    <section class="hero" aria-labelledby="hero-heading">
      <div class="hero-slides" aria-hidden="true">
        <div class="hero-slide" style="background-image:url('https://images.unsplash.com/photo-1474302770737-173ee21bab63?auto=format&fit=crop&w=2200&q=85')"></div>
        <div class="hero-slide" style="background-image:url('https://images.unsplash.com/photo-1436491865332-7a61a109cc05?auto=format&fit=crop&w=2200&q=85')"></div>
        <div class="hero-slide" style="background-image:url('https://images.unsplash.com/photo-1529074963764-98f45c47344b?auto=format&fit=crop&w=2200&q=85')"></div>
        <div class="hero-slide" style="background-image:url('https://images.unsplash.com/photo-1517479149777-5f3b1511d5ad?auto=format&fit=crop&w=2200&q=85')"></div>
      </div>
      <div class="hero-overlay"></div>
      <div class="hero-content">
        <p class="hero-eyebrow reveal" data-reveal>Air navigation safety · ATM assurance</p>
        <h1 id="hero-heading" class="hero-title reveal" data-reveal>
          Aviation safety assurance,<br />built for operational reality
        </h1>
        <p class="hero-lead reveal" data-reveal>
          {brand.siteName} helps aviation organisations strengthen safety, assurance, and operational decision-making through
          practical advisory support, independent review, and real-world systems thinking.
        </p>
        <div class="hero-actions reveal" data-reveal>
          <a class="btn btn-primary" href="/contact">Connect with us</a>
          <a class="btn btn-ghost" href="/services">Explore services</a>
        </div>
      </div>
    </section>

    <section class="section" id="about">
      <div class="container">
        <div class="grid-3">
          <article class="card reveal" data-reveal>
            <h2 style="margin-top:0;font-size:1.3rem">Operational grounding</h2>
            <p>Assurance shaped around how ANSP, airport, and programme teams actually run change and oversight day to day.</p>
          </article>
          <article class="card reveal reveal-delay-1" data-reveal>
            <h2 style="margin-top:0;font-size:1.3rem">Evidence you can defend</h2>
            <p>Traceable arguments, proportional controls, and artefacts structured for regulator and board scrutiny.</p>
          </article>
          <article class="card reveal reveal-delay-2" data-reveal>
            <h2 style="margin-top:0;font-size:1.3rem">Independent perspective</h2>
            <p>Clear challenge and advisory input where complexity, interfaces, and implementation risk need an experienced view.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="section section-muted" id="engagement-model">
      <div class="container split">
        <div>
          <p class="page-kicker reveal" data-reveal>Engagement model</p>
          <h2 class="section-title reveal reveal-delay-1" data-reveal>A clear path from risk to confidence</h2>
          <p class="section-lead reveal" data-reveal>
            AeroSure engagements follow a disciplined sequence so stakeholders can see how assurance is built and maintained through delivery.
          </p>
          <ul class="checklist reveal reveal-delay-1" data-reveal>
            <li><strong>Frame the change</strong> — scope, obligations, interfaces, and decision points.</li>
            <li><strong>Assess risk</strong> — hazards, barriers, and proportional controls.</li>
            <li><strong>Build assurance</strong> — evidence packs and stakeholder-ready narrative.</li>
            <li><strong>Embed and monitor</strong> — practical follow-through after deployment.</li>
          </ul>
        </div>
        <div class="card reveal reveal-delay-2" data-reveal>
          <img
            src="/about/team.png"
            alt="Aviation operations and safety assurance planning workspace"
            width="640"
            height="480"
            loading="lazy"
            style="border-radius:10px;margin-bottom:1rem"
          />
          <h3 style="margin:0 0 0.5rem">What this means for clients</h3>
          <p style="margin:0;color:var(--slate)">
            Better visibility of risk decisions, stronger internal alignment, and safer implementation confidence across ATM and air navigation programmes.
          </p>
        </div>
      </div>
    </section>

    <section class="section pathway-intro" id="service-pathways">
      <div class="container">
        <p class="page-kicker reveal" data-reveal>Service pathways</p>
        <h2 class="section-title reveal reveal-delay-1" data-reveal>Focused support across navigation safety, ATM assurance, and review</h2>
      </div>
    </section>

    <section class="pathway-strip strip-1">
      <div class="pathway-media" style="--pathway-img:url('https://images.unsplash.com/photo-1544016768-982d1554f0b9?auto=format&fit=crop&w=2200&q=85')"></div>
      <div class="container pathway-content-wrap">
        <article class="pathway-panel">
          <h3>Air navigation safety</h3>
          <p>
            Practical support for ANS safety performance, change-related risk, and assurance that reflects operational reality — not abstract compliance alone.
          </p>
          <p><a class="text-link" href="/services#air-navigation-safety">Open this service →</a></p>
        </article>
      </div>
    </section>

    <section class="pathway-strip strip-2">
      <div class="pathway-media" style="--pathway-img:url('https://images.unsplash.com/photo-1436491865332-7a61a109cc05?auto=format&fit=crop&w=2200&q=85')"></div>
      <div class="container pathway-content-wrap">
        <article class="pathway-panel">
          <h3>ATM assurance</h3>
          <p>
            Structured assurance for ATM change — evidence, verification intent, and operational release confidence aligned to programme pace.
          </p>
          <p><a class="text-link" href="/services#atm-assurance">Open this service →</a></p>
        </article>
      </div>
    </section>

    <section class="pathway-strip strip-3">
      <div class="pathway-media" style="--pathway-img:url('https://images.unsplash.com/photo-1529074963764-98f45c47344b?auto=format&fit=crop&w=2200&q=85')"></div>
      <div class="container pathway-content-wrap">
        <article class="pathway-panel">
          <h3>Independent review &amp; advisory</h3>
          <p>
            Challenge, peer review, and board-ready summaries that strengthen decision quality for safety-critical operational and technology change.
          </p>
          <p><a class="text-link" href="/services#independent-review-advisory">Open this service →</a></p>
        </article>
      </div>
    </section>

    <section class="section section-muted" id="projects">
      <div class="container">
        <p class="page-kicker reveal" data-reveal>Selected engagements</p>
        <h2 class="section-title reveal reveal-delay-1" data-reveal>Representative programme outcomes</h2>
        <div class="grid-3">
          <article class="card reveal" data-reveal>
            <h3>Major ATM upgrade</h3>
            <p>Safety case support and implementation assurance aligned to controlled operational release.</p>
          </article>
          <article class="card reveal reveal-delay-1" data-reveal>
            <h3>Assurance governance uplift</h3>
            <p>Clearer ownership across interfaces, stronger evidence quality, and faster assurance decisions.</p>
          </article>
          <article class="card reveal reveal-delay-2" data-reveal>
            <h3>Independent challenge review</h3>
            <p>Objective, board-ready assurance ahead of safety-critical milestones and regulatory engagement.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="section" id="services-icons">
      <div class="container">
        <p class="page-kicker reveal" data-reveal>Service catalogue</p>
        <h2 class="section-title reveal reveal-delay-1" data-reveal style="text-align:center">Core advisory areas</h2>
        <p class="section-lead reveal reveal-delay-2" data-reveal style="text-align:center;max-width:42rem;margin-left:auto;margin-right:auto">
          Each icon links to the matching section on the Services page.
        </p>
        <div class="icon-grid">
          {services.map((s, i) => (
            <a
              class={`icon-item reveal ${i === 0 ? "" : i === 1 ? "reveal-delay-1" : i === 2 ? "reveal-delay-2" : i === 3 ? "reveal-delay-3" : ""}`}
              data-reveal
              href={"/services#" + s.id}
              data-warp-link
              aria-label={"Open service: " + s.title}
            >
              {s.id === "air-navigation-safety" && (
                <svg viewBox="0 0 48 48" fill="none" aria-hidden="true">
                  <path d="M24 6L10 14v10c0 8 5 13 14 17 9-4 14-9 14-17V14L24 6z" stroke="currentColor" stroke-width="2" />
                  <path d="M18 22l4 4 8-8" stroke="currentColor" stroke-width="2" />
                </svg>
              )}
              {s.id === "atm-assurance" && (
                <svg viewBox="0 0 48 48" fill="none" aria-hidden="true">
                  <circle cx="24" cy="24" r="14" stroke="currentColor" stroke-width="2" />
                  <path d="M24 12v12l8 5" stroke="currentColor" stroke-width="2" />
                  <circle cx="24" cy="24" r="2.2" fill="currentColor" />
                </svg>
              )}
              {s.id === "safety-case-support" && (
                <svg viewBox="0 0 48 48" fill="none" aria-hidden="true">
                  <path d="M24 5L8 12v11c0 10 6.5 15.8 16 20 9.5-4.2 16-10 16-20V12L24 5z" stroke="currentColor" stroke-width="2" />
                  <path d="M17 24l5 5 9-9" stroke="currentColor" stroke-width="2" />
                </svg>
              )}
              {s.id === "operational-safety-reviews" && (
                <svg viewBox="0 0 48 48" fill="none" aria-hidden="true">
                  <path d="M8 36h32" stroke="currentColor" stroke-width="2" />
                  <path d="M12 36V20l8-4 8 4v16" stroke="currentColor" stroke-width="2" />
                  <path d="M28 36V22l8-3v17" stroke="currentColor" stroke-width="2" />
                  <circle cx="24" cy="12" r="3" stroke="currentColor" stroke-width="2" />
                </svg>
              )}
              {s.id === "risk-compliance-advisory" && (
                <svg viewBox="0 0 48 48" fill="none" aria-hidden="true">
                  <path d="M10 12h16v16H10zM22 20h16v16H22z" stroke="currentColor" stroke-width="2" />
                  <path d="M16 28l3 3 5-5" stroke="currentColor" stroke-width="2" />
                </svg>
              )}
              {s.id === "independent-review-advisory" && (
                <svg viewBox="0 0 48 48" fill="none" aria-hidden="true">
                  <path d="M12 14h24v22H12z" stroke="currentColor" stroke-width="2" />
                  <path d="M18 22l4 4 10-10" stroke="currentColor" stroke-width="2" />
                  <path d="M8 34h32" stroke="currentColor" stroke-width="2" opacity="0.5" />
                </svg>
              )}
              <span>{s.shortLabel}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="dark-cta" id="expertise-cta">
      <div class="dark-cta-bg" aria-hidden="true"></div>
      <div class="dark-cta-inner reveal" data-reveal>
        <h2>Need targeted support on a live safety challenge?</h2>
        <p>
          Connect for focused advisory input designed around ATM, air navigation, and high-assurance operational environments.
        </p>
        <a class="btn btn-primary btn-cta-blue" href="/contact">Connect with us <span aria-hidden="true">→</span></a>
      </div>
    </section>

    <section class="section" id="clients">
      <div class="container">
        <p class="page-kicker reveal" data-reveal>Trusted relationships</p>
        <h2 class="section-title reveal reveal-delay-1" data-reveal style="text-align:center">Who we support</h2>
      </div>
      <div class="marquee-clients" aria-hidden="true">
        <div class="marquee-track">
          <span class="client-item">ANSP programme office</span>
          <span class="client-item">Civil aviation authority</span>
          <span class="client-item">Military ATM</span>
          <span class="client-item">Airport operator</span>
          <span class="client-item">Systems integrator</span>
          <span class="client-item">Training academy</span>
          <span class="client-item">ANSP programme office</span>
          <span class="client-item">Civil aviation authority</span>
          <span class="client-item">Military ATM</span>
          <span class="client-item">Airport operator</span>
          <span class="client-item">Systems integrator</span>
          <span class="client-item">Training academy</span>
        </div>
      </div>
    </section>

    <section class="section section-muted" id="contact-preview">
      <div class="container split">
        <div>
          <h2 class="section-title reveal" data-reveal>Discuss your assurance needs with the team</h2>
          <p class="section-lead reveal reveal-delay-1" data-reveal>
            We welcome enquiries from operators, airports, ANSPs, regulators, and delivery partners seeking independent advisory support.
          </p>
          <p class="reveal reveal-delay-2" data-reveal>
            <a class="btn-pill-solid" href="/contact">Go to contact page <span aria-hidden="true">→</span></a>
          </p>
        </div>
        <form class="contact-form reveal reveal-delay-2" data-reveal action="#" method="post">
          <label>Name<input type="text" name="name" required autocomplete="name" /></label>
          <label>Work email<input type="email" name="email" required autocomplete="email" /></label>
          <label>Organisation<input type="text" name="org" autocomplete="organization" /></label>
          <label>Message<textarea name="message" required placeholder="How can we help?"></textarea></label>
          <button class="btn btn-primary" type="submit">Send message</button>
          <p class="form-note">Demo form for now — Supabase integration can be added next.</p>
        </form>
      </div>
    </section>
  </main>
</BaseLayout>

---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroSection from "../components/HeroSection.astro";
import CurvedDivider from "../components/CurvedDivider.astro";
import CTASection from "../components/CTASection.astro";
import DestinationCard from "../components/DestinationCard.astro";
import ItineraryCard from "../components/ItineraryCard.astro";
import { destinations, itineraries } from "../data/site.ts";

const homeDestinations = destinations.slice(0, 4);
const featuredVoyages = itineraries.slice(0, 3);

const whyItems = [
  {
    title: "Go Beyond",
    text: "Access remote places most travellers never see.",
    icon: `<circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>`,
  },
  {
    title: "Travel Together",
    text: "Small groups, big experiences, lasting bonds.",
    icon: `<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/>`,
  },
  {
    title: "Expert Guides",
    text: "Knowledgeable, passionate leaders in their field.",
    icon: `<circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/>`,
  },
  {
    title: "Immersive Experiences",
    text: "Curated excursions that inspire wonder.",
    icon: `<path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/>`,
  },
  {
    title: "Your Safety",
    text: "Industry-leading safety standards, always.",
    icon: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`,
  },
];

const testimonials = [
  {
    text: "Tideborne Voyages exceeded every expectation. The ship, the crew, the experiences. Simply world class.",
    author: "Daniel R.",
    detail: "Verified Guest · Antarctica Explorer",
  },
  {
    text: "Watching whales surface beside our Zodiac while a naturalist narrated every moment. That's something no large ship could ever offer.",
    author: "Priya S.",
    detail: "Verified Guest · Svalbard Expedition",
  },
  {
    text: "From the first phone call to the final sunset, every detail felt considered. We returned home changed.",
    author: "Margaret & Tom H.",
    detail: "Verified Guests · Galápagos Adventure",
  },
];
---

<BaseLayout
  title="Tideborne Voyages | Boutique Expedition Cruises to Remote Destinations"
  description="Extraordinary places, meaningful journeys. Boutique expedition cruises to Antarctica, Iceland, the Galápagos, and Norway, led by experts and inspired by nature."
>
  <main id="main">
    <!-- 1. Hero -->
    <HeroSection
      image="/assets/tideborne/backgrounds/home-hero-clean.jpg"
      position="center 38%"
      eyebrow="Explore the world. Leave nothing but wake."
      lead="Boutique expedition cruises to the world's most remote destinations, led by experts and inspired by nature."
    >
      Extraordinary Places.<br /><em>Meaningful Journeys.</em>
      <Fragment slot="actions">
        <a class="btn btn-gold" href="/expedition-cruises">
          Explore Voyages <span class="btn-arrow" aria-hidden="true">→</span>
        </a>
        <a class="btn btn-ghost-light" href="/our-ships">View Expedition Ships</a>
      </Fragment>
    </HeroSection>

    <!-- 2. Proof strip -->
    <section class="proof-strip" aria-label="Why guests trust Tideborne">
      <div class="container">
        <div class="proof-grid reveal">
          <div class="proof-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 15a7 7 0 1 0 0-14 7 7 0 0 0 0 14z"/><path d="M8.21 13.89 7 23l5-3 5 3-1.21-9.12"/></svg>
            <span class="proof-value">20+</span>
            <span class="proof-label">Years of<br />Exploration</span>
          </div>
          <div class="proof-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            <span class="proof-value">100+</span>
            <span class="proof-label">Unique<br />Itineraries</span>
          </div>
          <div class="proof-item">
            <span class="proof-value" style="letter-spacing:0.08em;font-size:1.15rem">TRAVEL+<br />LEISURE</span>
            <span class="proof-label">World's Best<br />Small Ship Cruise Line</span>
          </div>
          <div class="proof-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <span class="proof-value">98%</span>
            <span class="proof-label">Guest Satisfaction<br />Rating</span>
          </div>
          <div class="proof-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>
            <span class="proof-label" style="margin-top:0.4rem">Sustainable<br />Tourism Partner</span>
          </div>
        </div>
      </div>
    </section>

    <CurvedDivider from="cream" to="navy" flip />

    <!-- 3. Iconic destinations -->
    <section class="section section-navy topographic-bg on-dark" aria-labelledby="destinations-heading">
      <div class="container">
        <div class="section-intro-grid">
          <div class="reveal">
            <p class="eyebrow">Curated Destinations</p>
            <h2 class="serif-title title-lg" id="destinations-heading">
              Iconic Places.<br /><em>Untouched Beauty.</em>
            </h2>
            <p class="lead">
              From polar wilderness to hidden shores, our itineraries take you beyond the ordinary.
            </p>
            <a class="text-link" href="/destinations">
              Explore Destinations <span class="btn-arrow" aria-hidden="true">→</span>
            </a>
          </div>
          <div class="reveal reveal-delay-1" style="display:flex;justify-content:flex-end;align-items:flex-end">
            <div class="scroller-controls">
              <button class="scroller-btn" type="button" data-scroll-target="home-destinations" data-dir="-1" aria-label="Scroll destinations backwards">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
              </button>
              <button class="scroller-btn" type="button" data-scroll-target="home-destinations" data-dir="1" aria-label="Scroll destinations forwards">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
              </button>
            </div>
          </div>
        </div>
        <div class="card-scroller reveal reveal-delay-1" id="home-destinations">
          {homeDestinations.map((d) => <DestinationCard destination={d} />)}
        </div>
      </div>
    </section>

    <CurvedDivider from="navy" to="cream-2" />

    <!-- 4. Featured voyages -->
    <section class="section section-cream-2 on-cream" aria-labelledby="voyages-heading" style="padding-top:3.5rem">
      <div class="container">
        <div class="section-intro-grid" style="align-items:start">
          <div class="reveal">
            <p class="eyebrow">Featured Voyages</p>
            <h2 class="serif-title title-lg" id="voyages-heading">
              Handcrafted Itineraries.<br /><em>Unforgettable Moments.</em>
            </h2>
            <p class="lead">
              Thoughtfully curated voyages with expert guides, small groups, and immersive experiences.
            </p>
            <a class="text-link on-cream-link" href="/expedition-cruises">
              View All Itineraries <span class="btn-arrow" aria-hidden="true">→</span>
            </a>
          </div>
          <div class="reveal reveal-delay-1" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(230px,1fr));gap:1.4rem">
            {featuredVoyages.map((it) => <ItineraryCard itinerary={it} compact />)}
          </div>
        </div>
        <div class="custom-voyage-card reveal">
          <img class="compass-accent" src="/assets/tideborne/decor/gold-compass-small.svg" alt="" width="46" height="46" />
          <div>
            <h3 class="serif-title title-md" style="margin-bottom:0.4rem;color:var(--tide-navy-900)">Custom Voyages</h3>
            <p style="margin:0;color:rgba(4,30,45,0.68);font-size:0.94rem;max-width:36rem">
              Have a destination in mind? Let us craft a journey tailored just for you: private charters,
              extended expeditions, and one-of-a-kind routes.
            </p>
          </div>
          <a class="btn btn-ghost-dark" href="/contact">
            Learn More <span class="btn-arrow" aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </section>

    <!-- 5. Why travel with Tideborne -->
    <section class="section section-cream on-cream" aria-labelledby="why-heading">
      <div class="container">
        <div class="section-intro-grid" style="align-items:start">
          <div class="reveal">
            <p class="eyebrow">Why Travel With Tideborne</p>
            <h2 class="serif-title title-lg" id="why-heading">
              More Than a Cruise.<br /><em>A Deeper Connection.</em>
            </h2>
            <p class="lead">
              Every detail is designed to bring you closer to the world and to what matters most.
            </p>
            <a class="text-link on-cream-link" href="/experience">
              Our Difference <span class="btn-arrow" aria-hidden="true">→</span>
            </a>
          </div>
          <div class="feature-icon-row reveal reveal-delay-1">
            {
              whyItems.map((item) => (
                <div class="feature-icon">
                  <span class="feature-icon-circle">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={item.icon} />
                  </span>
                  <h3 class="feature-icon-title">{item.title}</h3>
                  <p class="feature-icon-text">{item.text}</p>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <!-- 6. Guest stories / responsible travel split -->
    <section class="story-split" aria-label="Guest stories and responsible travel">
      <div class="story-panel story-panel-dark on-dark reveal">
        <p class="eyebrow">Guest Stories</p>
        <h2 class="serif-title title-md on-dark">
          Trusted by Explorers.<br /><em>Loved by Guests.</em>
        </h2>
        <div id="testimonial-rotor">
          {
            testimonials.map((t, i) => (
              <blockquote class:list={["testimonial-slide", { "is-active": i === 0 }]} data-index={String(i)}>
                <span class="testimonial-quote-mark" aria-hidden="true">“</span>
                <p class="testimonial-text">{t.text}</p>
                <div class="testimonial-stars" aria-label="Five star review">★★★★★</div>
                <p class="testimonial-author">{t.author}<span>{t.detail}</span></p>
              </blockquote>
            ))
          }
        </div>
        <div class="testimonial-controls">
          <button class="scroller-btn" type="button" data-testimonial-dir="-1" aria-label="Previous guest story">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
          </button>
          <div class="testimonial-dots" role="presentation">
            {testimonials.map((_, i) => (
              <button type="button" class:list={[{ "is-active": i === 0 }]} data-testimonial-dot={String(i)} aria-label={`Show guest story ${i + 1}`}></button>
            ))}
          </div>
          <button class="scroller-btn" type="button" data-testimonial-dir="1" aria-label="Next guest story">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
          </button>
        </div>
      </div>
      <div class="story-image">
        <img
          src="/assets/tideborne/about/zodiac-whale-clean.jpg"
          alt="Guests in a Zodiac watching a whale surface near a glacier"
          loading="lazy"
          width="900"
          height="700"
        />
      </div>
      <div class="story-panel story-panel-cream on-cream reveal">
        <p class="eyebrow">Travel Responsibly</p>
        <h2 class="serif-title title-md on-cream">
          Protecting Places.<br /><em>Preserving Wonder.</em>
        </h2>
        <p class="lead" style="margin-bottom:1.4rem">
          We are committed to sustainable travel and supporting the communities and environments we explore.
        </p>
        <a class="text-link on-cream-link" href="/about#sustainability">
          Our Commitment <span class="btn-arrow" aria-hidden="true">→</span>
        </a>
        <div class="story-partners" aria-label="Conservation partners">
          <span>Sustainable Tourism Partner</span>
          <span>1% For the Planet</span>
          <span>AECO Member</span>
        </div>
      </div>
    </section>

    <!-- 7. CTA -->
    <CTASection
      image="/assets/tideborne/backgrounds/whale-ocean-clean.jpg"
      position="center 62%"
      title="Your Next Extraordinary Journey Awaits."
      text="Let our Voyage Specialists help you find the perfect expedition."
    >
      <Fragment slot="actions">
        <a class="btn btn-gold" href="/contact">Request a Brochure</a>
        <a class="btn btn-ghost-light" href="/contact">Contact a Specialist</a>
      </Fragment>
    </CTASection>
  </main>
</BaseLayout>

<style>
  .custom-voyage-card {
    margin-top: 2.5rem;
    display: flex;
    align-items: center;
    gap: 1.75rem;
    flex-wrap: wrap;
    background: var(--tide-cream);
    border: 1px solid rgba(201, 154, 72, 0.4);
    border-radius: 14px;
    padding: 1.75rem 2rem;
  }
  .custom-voyage-card > div { flex: 1 1 320px; }

  .story-split {
    display: grid;
    grid-template-columns: 1.1fr 1fr 1.1fr;
    background: var(--tide-navy-900);
  }
  .story-panel { padding: 4rem 3rem; display: flex; flex-direction: column; justify-content: center; }
  .story-panel-dark { background: var(--tide-navy-900); }
  .story-panel-cream { background: var(--tide-cream); }
  .story-image { position: relative; min-height: 360px; }
  .story-image img {
    position: absolute; inset: 0; width: 100%; height: 100%;
    object-fit: cover; object-position: center 70%;
  }

  .testimonial-slide { display: none; margin: 0; }
  .testimonial-slide.is-active { display: block; animation: tideFadeUp 0.55s var(--ease); }
  .testimonial-controls { display: flex; align-items: center; gap: 1.1rem; margin-top: 1.6rem; }
  .testimonial-dots { display: flex; gap: 0.45rem; }
  .testimonial-dots button {
    width: 8px; height: 8px; border-radius: 50%; border: 0; padding: 0;
    background: rgba(244, 239, 228, 0.3); cursor: pointer; transition: background 0.25s;
  }
  .testimonial-dots button.is-active { background: var(--tide-gold); }

  .story-partners {
    display: flex; flex-wrap: wrap; gap: 0.6rem 1.5rem; margin-top: 2.25rem;
    padding-top: 1.5rem; border-top: 1px solid rgba(4, 30, 45, 0.14);
  }
  .story-partners span {
    font-size: 0.64rem; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase;
    color: rgba(4, 30, 45, 0.55);
  }

  @media (max-width: 1080px) {
    .story-split { grid-template-columns: 1fr 1fr; }
    .story-image { grid-column: 1 / -1; order: -1; min-height: 300px; }
  }
  @media (max-width: 720px) {
    .story-split { grid-template-columns: 1fr; }
    .story-panel { padding: 3rem 1.5rem; }
  }
</style>

<script>
  // Destination card scroller arrows
  document.querySelectorAll<HTMLButtonElement>("[data-scroll-target]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const target = document.getElementById(btn.dataset.scrollTarget || "");
      if (!target) return;
      const card = target.firstElementChild as HTMLElement | null;
      const step = card ? card.offsetWidth + 22 : 300;
      target.scrollBy({ left: step * Number(btn.dataset.dir || 1), behavior: "smooth" });
    });
  });

  // Testimonial rotor
  const slides = Array.from(document.querySelectorAll<HTMLElement>(".testimonial-slide"));
  const dots = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-testimonial-dot]"));
  let current = 0;
  function showTestimonial(index: number) {
    current = (index + slides.length) % slides.length;
    slides.forEach((s, i) => s.classList.toggle("is-active", i === current));
    dots.forEach((d, i) => d.classList.toggle("is-active", i === current));
  }
  document.querySelectorAll<HTMLButtonElement>("[data-testimonial-dir]").forEach((btn) => {
    btn.addEventListener("click", () => showTestimonial(current + Number(btn.dataset.testimonialDir)));
  });
  dots.forEach((dot) => {
    dot.addEventListener("click", () => showTestimonial(Number(dot.dataset.testimonialDot)));
  });
  if (slides.length > 1) {
    setInterval(() => showTestimonial(current + 1), 9000);
  }
</script>

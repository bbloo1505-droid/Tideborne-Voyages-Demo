---
import BaseLayout from "../layouts/BaseLayout.astro";
import { brand } from "../data/brand.ts";
---

<BaseLayout
  title={`Privacy | ${brand.siteName}`}
  description="Privacy notice for AeroSure Advisory website enquiries."
>
  <main id="main" class="container page-shell">
    <section class="page-hero reveal" data-reveal>
      <p class="page-kicker">Privacy</p>
      <h1 class="section-title">Privacy notice</h1>
      <p class="section-lead">How AeroSure Advisory handles information submitted through this website.</p>
    </section>

    <section class="card reveal" data-reveal>
      <h2 class="section-title" style="font-size:1.45rem">Data we collect</h2>
      <p class="section-lead" style="margin-bottom:0.75rem">
        If you contact AeroSure Advisory through a form or email, we may collect your name, email address, organisation, and message content.
      </p>
      <p class="section-lead" style="margin:0">
        This information is used only to respond to your enquiry and manage service discussions.
      </p>
    </section>
  </main>
</BaseLayout>

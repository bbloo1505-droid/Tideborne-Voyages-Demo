---
import BaseLayout from "../layouts/BaseLayout.astro";
import { services } from "../data/services.ts";
import { brand } from "../data/brand.ts";
---

<BaseLayout
  title={`Services | ${brand.siteName}`}
  description="AeroSure Advisory services: air navigation safety, ATM assurance, safety case support, operational reviews, risk and compliance advisory, and independent review."
>
  <main id="main" class="container page-shell">
    <section class="page-hero reveal" data-reveal>
      <p class="page-kicker">Services</p>
      <h1 class="section-title">Aviation safety services built for operational delivery</h1>
      <p class="section-lead" style="max-width:42rem">
        Advisory streams for ATM, air navigation, and high-assurance change. Each section links directly from the homepage.
      </p>
    </section>

    <section class="section" style="padding:0 0 2rem">
      <div class="grid-3">
        <article class="card reveal" data-reveal>
          <h3>Scope and framing</h3>
          <p>Define safety objectives, interfaces, and required evidence early to reduce programme uncertainty.</p>
        </article>
        <article class="card reveal reveal-delay-1" data-reveal>
          <h3>Risk and control design</h3>
          <p>Build proportionate, traceable controls that align with operational realities and regulatory intent.</p>
        </article>
        <article class="card reveal reveal-delay-2" data-reveal>
          <h3>Assurance close-out</h3>
          <p>Deliver clear assurance narratives and artefacts ready for governance, oversight, and deployment.</p>
        </article>
      </div>
    </section>

    <section class="page-photo-stack">
      <article class="page-photo-band">
        <div class="page-photo-media" style="--band-img:url('https://images.unsplash.com/photo-1436491865332-7a61a109cc05?auto=format&fit=crop&w=2200&q=85')"></div>
        <div class="page-photo-content">
          <div class="page-photo-card reveal" data-reveal>
            <h3>Service delivery aligned to programme pace</h3>
            <p>
              Support can be embedded into active projects, targeted to milestones, or delivered as focused assurance sprints where rapid clarity is needed.
            </p>
          </div>
        </div>
      </article>
      <article class="page-photo-band">
        <div class="page-photo-media" style="--band-img:url('https://images.unsplash.com/photo-1504196606672-aef5c9cefc92?auto=format&fit=crop&w=2200&q=85')"></div>
        <div class="page-photo-content">
          <div class="page-photo-card reveal reveal-delay-1" data-reveal>
            <h3>Evidence quality at the centre</h3>
            <p>
              Every service stream is designed to improve traceability, strengthen oversight confidence, and reduce rework in later assurance stages.
            </p>
          </div>
        </div>
      </article>
    </section>

    <section class="section section-muted" style="margin:0 -1.25rem;padding:3.25rem 1.25rem">
      <div class="container">
        <p class="page-kicker reveal" data-reveal>Service details</p>
        <h2 class="section-title reveal reveal-delay-1" data-reveal>Core delivery areas</h2>
      </div>
      <div class="container" style="display:grid;gap:2rem">
        {services.map((s) => (
          <section class="service-detail card reveal" data-reveal id={s.id} style="background:#fff">
            <h2 class="section-title" style="font-size:1.6rem;margin-bottom:0.75rem">{s.title}</h2>
            <p class="section-lead" style="margin:0 0 0.75rem">{s.blurb}</p>
            <p style="margin:0;color:var(--slate)">
              Engagement format: focused review workshops, artefact development support, and implementation guidance tailored to your programme phase.
            </p>
          </section>
        ))}
      </div>
    </section>

    <section class="section" style="padding:3rem 0 0">
      <div class="card reveal" data-reveal>
        <h3 style="margin-top:0">Need help selecting the right service pathway?</h3>
        <p class="section-lead" style="margin:0 0 1rem">
          Share your current challenge and timeline. AeroSure can propose a proportionate engagement model before detailed scoping.
        </p>
        <a class="btn btn-primary" href="/contact">Connect with us to discuss your needs</a>
      </div>
    </section>
  </main>
</BaseLayout>

---
/**
 * Inquiry form with client-side validation and a success state.
 * `variant="compact"` renders a shorter version for inline panels.
 */
interface Props {
  variant?: "full" | "compact";
  id?: string;
}

const { variant = "full", id = "inquiry-form" } = Astro.props;
const isFull = variant === "full";
---

<form class="form-grid" data-tide-form id={id} novalidate>
  <div class="form-row">
    <div class="form-field">
      <label for={`${id}-name`}>Full Name</label>
      <input type="text" id={`${id}-name`} name="name" placeholder="Jane Doe" autocomplete="name" required />
      <p class="form-error">Please enter your full name.</p>
    </div>
    <div class="form-field">
      <label for={`${id}-email`}>Email Address</label>
      <input type="email" id={`${id}-email`} name="email" placeholder="jane.doe@example.com" autocomplete="email" required />
      <p class="form-error">Please enter a valid email address.</p>
    </div>
  </div>

  {
    isFull && (
      <div class="form-row">
        <div class="form-field">
          <label for={`${id}-phone`}>Phone Number</label>
          <input type="tel" id={`${id}-phone`} name="phone" placeholder="+1 (216) 555-0134" autocomplete="tel" />
          <p class="form-error">Please enter a valid phone number.</p>
        </div>
        <div class="form-field">
          <label for={`${id}-contact-method`}>Preferred Contact Method</label>
          <select id={`${id}-contact-method`} name="contactMethod">
            <option>Email</option>
            <option>Phone</option>
            <option>Either</option>
          </select>
        </div>
      </div>
    )
  }

  <div class="form-row">
    <div class="form-field">
      <label for={`${id}-destination`}>Destination of Interest</label>
      <select id={`${id}-destination`} name="destination">
        <option>Not sure yet</option>
        <option>Antarctica</option>
        <option>Iceland &amp; Greenland</option>
        <option>Galápagos</option>
        <option>Norway &amp; Fjords</option>
        <option>Arctic Svalbard</option>
        <option>Scotland &amp; Hebrides</option>
        <option>Raja Ampat</option>
      </select>
    </div>
    <div class="form-field">
      <label for={`${id}-dates`}>Travel Dates (Optional)</label>
      <input type="text" id={`${id}-dates`} name="dates" placeholder="June 2026" />
    </div>
  </div>

  {
    isFull && (
      <div class="form-field">
        <label for={`${id}-travellers`}>Number of Travellers</label>
        <select id={`${id}-travellers`} name="travellers">
          <option>1 Traveller</option>
          <option selected>2 Travellers</option>
          <option>3 Travellers</option>
          <option>4 Travellers</option>
          <option>5+ Travellers</option>
        </select>
      </div>
    )
  }

  <div class="form-field">
    <label for={`${id}-message`}>Tell Us About Your Ideal Journey {isFull ? "(Optional)" : ""}</label>
    <textarea
      id={`${id}-message`}
      name="message"
      placeholder="We're celebrating our 25th anniversary and love wildlife and photography."
    ></textarea>
  </div>

  {
    isFull && (
      <label class="form-checkbox">
        <input type="checkbox" name="newsletter" checked />
        <span>Yes, I'd like to receive exclusive offers and inspiration from Tideborne Voyages.</span>
      </label>
    )
  }

  <div>
    <button class="btn btn-gold" type="submit">
      Send Inquiry <span class="btn-arrow" aria-hidden="true">→</span>
    </button>
  </div>

  <p class="form-success" role="status">
    <strong>Thank you — your inquiry is on its way.</strong><br />
    A Voyage Specialist will be in touch within one business day to begin planning your expedition.
  </p>
</form>

<script>
  function initForms() {
    document.querySelectorAll<HTMLFormElement>("form[data-tide-form]").forEach((form) => {
      if (form.dataset.bound) return;
      form.dataset.bound = "1";

      const validateField = (input: HTMLInputElement | HTMLTextAreaElement): boolean => {
        const field = input.closest(".form-field");
        if (!field) return true;
        let valid = true;
        const value = input.value.trim();
        if (input.required && value === "") valid = false;
        if (valid && input.type === "email" && value !== "" && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value)) valid = false;
        if (valid && input.type === "tel" && value !== "" && !/^[+()\d\s.-]{7,}$/.test(value)) valid = false;
        field.classList.toggle("has-error", !valid);
        return valid;
      };

      form.querySelectorAll<HTMLInputElement>("input, textarea").forEach((input) => {
        input.addEventListener("input", () => {
          input.closest(".form-field")?.classList.remove("has-error");
        });
        input.addEventListener("blur", () => {
          if (input.value.trim() !== "" || input.required) validateField(input);
        });
      });

      form.addEventListener("submit", (e) => {
        e.preventDefault();
        let allValid = true;
        form.querySelectorAll<HTMLInputElement>("input:not([type=checkbox]), textarea").forEach((input) => {
          if (!validateField(input)) allValid = false;
        });
        if (!allValid) {
          (form.querySelector(".has-error input, .has-error textarea") as HTMLElement | null)?.focus();
          return;
        }
        const success = form.querySelector(".form-success");
        success?.classList.add("is-visible");
        Array.from(form.children).forEach((child) => {
          if (!child.classList.contains("form-success")) {
            (child as HTMLElement).style.display = "none";
          }
        });
        success?.scrollIntoView({ behavior: "smooth", block: "center" });
      });
    });
  }
  initForms();
</script>

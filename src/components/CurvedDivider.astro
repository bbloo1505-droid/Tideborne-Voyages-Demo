---
/**
 * Curved wave divider placed between two sections.
 * `from` paints the strip background (the section above),
 * `to` paints the wave itself (the section below).
 */
interface Props {
  from: "cream" | "cream-2" | "navy" | "navy-deep" | "transparent";
  to: "cream" | "cream-2" | "navy" | "navy-deep";
  flip?: boolean;
}

const colors: Record<string, string> = {
  cream: "#F4EFE4",
  "cream-2": "#FBF7EF",
  navy: "#041E2D",
  "navy-deep": "#031723",
  transparent: "transparent",
};

const { from, to, flip = false } = Astro.props;
---

<div class="wave-divider" style={`background:${colors[from]}`} aria-hidden="true">
  <svg
    viewBox="0 0 1600 180"
    preserveAspectRatio="none"
    style={flip ? "transform:scaleX(-1)" : undefined}
  >
    <path
      d="M0 74C190 130 370 120 560 82C760 42 890 14 1070 70C1250 126 1420 126 1600 68V180H0V74Z"
      fill={colors[to]}></path>
  </svg>
</div>

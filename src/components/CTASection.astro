---
/**
 * Full-width image CTA band. Slot `actions` renders the buttons.
 */
interface Props {
  image: string;
  title: string;
  text?: string;
}

const { image, title, text } = Astro.props;
---

<section class="cta-banner" style={`background-image:url('${image}')`}>
  <div class="container cta-banner-inner">
    <div class="reveal">
      <h2 class="serif-title title-lg">{title}</h2>
      {text && <p>{text}</p>}
    </div>
    <div class="cta-banner-actions reveal reveal-delay-1">
      <slot name="actions" />
    </div>
  </div>
</section>

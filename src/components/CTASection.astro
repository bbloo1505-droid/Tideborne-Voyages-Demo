---
/**
 * Full-width CTA band. Slot `actions` renders the buttons.
 * With no `image`, renders a premium navy gradient + topographic texture.
 */
interface Props {
  image?: string;
  title: string;
  text?: string;
  /** CSS background-position focal point for the image. */
  position?: string;
}

const { image, title, text, position = "center" } = Astro.props;
const bgStyle = image
  ? `background-image:url('${image}');background-position:${position}`
  : undefined;
---

<section class:list={["cta-banner", { "cta-banner-plain": !image }]} style={bgStyle}>
  <div class="container cta-banner-inner">
    <div class="reveal">
      <h2 class="serif-title title-lg">{title}</h2>
      {text && <p>{text}</p>}
    </div>
    <div class="cta-banner-actions reveal reveal-delay-1">
      <slot name="actions" />
    </div>
  </div>
</section>
